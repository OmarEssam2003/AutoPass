# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────
# Replace these with your actual pgAdmin credentials
DB_HOST=localhost
DB_PORT=5432
DB_NAME=AutoPass_V2
DB_USER=postgres
DB_PASSWORD=Om@rEssam2003

# ─── JWT ──────────────────────────────────────────────────
# Replace with any long random string (min 32 characters)
# Example generator: open node and run → require('crypto').randomBytes(64).toString('hex')
JWT_SECRET=replace_this_with_a_long_random_secret_key_min_32_chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace_this_with_another_long_random_secret_for_refresh
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_POINTS=10
RATE_LIMIT_DURATION=1